<view class="page">
  <view class="hero">
    <text class="h1 hero-title">十分太满</text>
    <text class="h1 hero-accent">七分刚好</text>
    <text class="caption hero-sub">吃饭是这样，生活也是</text>
  </view>
  <view class="section">
    <view class="flex-between px-md">
      <text class="label">今日饮食</text>
      <text class="caption">{{todayDate}}</text>
    </view>
    <view class="meal-list">
      <block wx:for="{{mealSlots}}" wx:key="type">
        <view class="card meal-card" bindtap="goRecord" data-type="{{item.type}}">
          <view class="flex-between">
            <view class="flex gap-sm">
              <text class="meal-icon">{{item.icon}}</text>
              <view class="flex-col">
                <text class="meal-label">{{item.label}}</text>
                <text class="meal-time">{{item.time}}</text>
              </view>
            </view>
            <view class="meal-content" wx:if="{{item.hasContent}}">
              <text class="body">{{item.content}}</text>
            </view>
            <view class="meal-empty" wx:else>
              <text class="caption">+ 记录</text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>
  <view class="fab" bindtap="goRecord">
    <text class="fab-icon">+</text>
  </view>
</view>
