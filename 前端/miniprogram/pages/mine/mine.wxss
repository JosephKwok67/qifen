.page { min-height: 100vh; }
.profile-card { margin: 0; }
.avatar { width: 80rpx; height: 80rpx; border-radius: 40rpx; background: var(--accent); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: 600; }
.menu-section { background: var(--bg-card); border-radius: 16rpx; overflow: hidden; margin: 0; }
.menu-item { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 28rpx; }
.arrow { font-size: 36rpx; }
.footer { text-align: center; padding: 48rpx 0; }
switch { transform: scale(0.84); }
