<view class="page p-md">
  <view class="profile-card card">
    <view class="flex gap-sm">
      <view class="avatar">{{avatarLetter}}</view>
      <view class="flex-col">
        <text class="h3">{{nickname}}</text>
        <text class="caption mt-xs">十分太满，七分刚好</text>
      </view>
    </view>
  </view>

  <view class="menu-section mt-md">
    <view class="menu-item" bindtap="toggleTheme">
      <text class="body">深色模式</text>
      <switch checked="{{isDark}}" bindchange="toggleTheme" color="var(--accent)" />
    </view>
    <view class="divider" />
    <view class="menu-item" bindtap="goHistory">
      <text class="body">历史记录</text>
      <text class="caption arrow">›</text>
    </view>
    <view class="divider" />
    <view class="menu-item" bindtap="about">
      <text class="body">关于七分</text>
      <text class="caption arrow">›</text>
    </view>
  </view>

  <view class="footer caption">
    <text>七分 v1.0.0</text>
  </view>
</view>
