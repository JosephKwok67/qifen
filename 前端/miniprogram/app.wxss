/* === 七分 Design System === */

page {
  --bg: #f7f5f0;
  --bg-card: #ffffff;
  --text: #3a3028;
  --text-secondary: #8a7a6a;
  --text-muted: #b5a99a;
  --accent: #c4a882;
  --accent-dark: #5a4a3a;
  --border: #ebe5dc;
  --divider: #f0ebe2;
  --status-safe: #8fb996;
  --status-warn: #d4a853;
  --status-danger: #c97b6b;

  background-color: var(--bg);
  color: var(--text);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

@media (prefers-color-scheme: dark) {
  page {
    --bg: #1a1a1a;
    --bg-card: #2a2a2a;
    --text: #e8d5a3;
    --text-secondary: #a09880;
    --text-muted: #6a6050;
    --accent: #e8d5a3;
    --accent-dark: #c4a882;
    --border: #3a3a3a;
    --divider: #2a2a2a;
    --status-safe: #6a9a7a;
    --status-warn: #c4a853;
    --status-danger: #b97b6b;
  }
}

/* === Typography === */
.h1 { font-size: 52rpx; font-weight: 700; line-height: 1.3; }
.h2 { font-size: 40rpx; font-weight: 600; line-height: 1.35; }
.h3 { font-size: 32rpx; font-weight: 600; line-height: 1.4; }
.body { font-size: 28rpx; line-height: 1.6; }
.caption { font-size: 24rpx; color: var(--text-secondary); }
.label { font-size: 22rpx; color: var(--text-muted); text-transform: uppercase; letter-spacing: 2rpx; }

/* === Spacing === */
.p-0 { padding: 0; }
.p-xs { padding: 12rpx; }
.p-sm { padding: 20rpx; }
.p-md { padding: 32rpx; }
.p-lg { padding: 48rpx; }

.mt-xs { margin-top: 12rpx; }
.mt-sm { margin-top: 20rpx; }
.mt-md { margin-top: 32rpx; }
.mt-lg { margin-top: 48rpx; }

/* === Cards === */
.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 28rpx;
  margin: 16rpx 24rpx;
}

/* === Divider === */
.divider {
  height: 1rpx;
  background: var(--divider);
  margin: 24rpx 0;
}

/* === Button === */
.btn-primary {
  background: var(--accent);
  color: #fff;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}
.btn-primary:active { opacity: 0.85; }

.btn-ghost {
  background: transparent;
  color: var(--accent);
  border: 2rpx solid var(--accent);
  border-radius: 48rpx;
  padding: 18rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
}

/* === Status dots === */
.dot-safe { color: var(--status-safe); }
.dot-warn { color: var(--status-warn); }
.dot-danger { color: var(--status-danger); }

/* === Flex helpers === */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; }
.gap-xs { gap: 12rpx; }
.gap-sm { gap: 20rpx; }
.gap-md { gap: 32rpx; }
